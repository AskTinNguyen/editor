{
  "extends": "../../packages/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@pascal-app/editor": ["./src/renderer/src/types/pascal-editor.d.ts"],
      "@/*": ["./src/renderer/src/*"]
    }
  },
  "include": ["electron.vite.config.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
